# =============================================================================
# CamPark Environment Template
# Copy to .env and fill in values before starting the stack.
#   cp .env.example .env
# =============================================================================

# Docker Compose project name — REQUIRED on new deploys.
# This fixes the Docker volume name prefix regardless of directory name.
COMPOSE_PROJECT_NAME=camv1

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_PASSWORD=changeme_strong_password_here

# Full connection string — used by api and worker containers.
# In docker compose, host = service name (postgres).
DATABASE_URL=postgresql://campark:changeme_strong_password_here@postgres:5432/campark

# =============================================================================
# Admin / API
# =============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password_here

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-random-32-character-string

# Set to true to require X-API-Key header on all /api/v1/* routes for external clients.
REQUIRE_API_KEY=false

# =============================================================================
# FTP Server
# =============================================================================
# The public IP cameras will connect to for FTP passive mode.
FTP_PUBLICHOST=34.87.50.204

# Bootstrap FTP users (comma-separated user:pass pairs).
# Used only on first boot. Cameras added via admin UI override this.
FTP_USERS=cam001:password123

# Passive port range — must match Docker port mapping.
FTP_PASSIVE_PORTS=30000:30049

# =============================================================================
# Worker — YOLO Inference
# =============================================================================
YOLO_ENABLED=true
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.50
OVERLAP_THRESHOLD=0.15

# Zone classifier mode: placeholder (no model) | onnx (trained model)
ZONECLS_MODE=placeholder
ZONECLS_MODEL_PATH=/models/zonecls.onnx
ZONECLS_THRESHOLD=0.55

# Operating hours (local time, 24h, inclusive start exclusive end).
# Stored in system_settings table — override here for initial seeding.
OPERATING_HOURS_START=0
OPERATING_HOURS_END=24

# Perceptual diff threshold — frames with delta below this are skipped.
# Lower = more sensitive (more CPU use). 6.0 is a good default.
SCENE_DIFF_THRESHOLD=6.0

# Timezone for operating hours and timestamps (IANA name).
CAMERA_TZ=Asia/Kuala_Lumpur

# Worker parallelism — number of camera processing threads.
# Default: min(cpu_count, 16). Override if you want fewer.
# WORKER_THREADS=4

# Draw YOLO bounding box overlays on saved snapshots (for debugging).
EVIDENCE_OVERLAY_ENABLED=false

# =============================================================================
# Worker — Queue / Redis
# =============================================================================
YOLO_QUEUE_REDIS=redis:6379

# Fall back to DB polling if Redis is unavailable.
REDIS_USE_DB_FALLBACK=true

# =============================================================================
# Camera Health Monitor
# =============================================================================
ENABLE_HEALTH_MONITOR=true
HEALTH_INTERVAL_SECONDS=30
STALE_SECONDS=150
OFFLINE_SECONDS=300

# =============================================================================
# Telegram Alerts (optional)
# =============================================================================
# Leave blank to disable Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# GCS Bucket Sync (optional — for dataset/tuning pipeline)
# =============================================================================
GCS_BUCKET=campark-tuning-amirl-2026

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

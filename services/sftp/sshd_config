Protocol 2
HostKey /etc/ssh/ssh_host_ed25519_key
HostKey /etc/ssh/ssh_host_rsa_key

# Only allow SFTP subsystem — no shell access
Subsystem sftp internal-sftp -d /upload

UseDNS no
PermitRootLogin no
X11Forwarding no
AllowTcpForwarding no

# All users are chroot-jailed and start inside /upload automatically
Match Group sftpusers
    ChrootDirectory %h
    ForceCommand internal-sftp -d /upload
    AllowTcpForwarding no
    X11Forwarding no
